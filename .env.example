APP_NAME=NAATIA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Mexico_City

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -------- Logging --------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------- Database --------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=naatia
DB_USERNAME=root
DB_PASSWORD=

# -------- Session & cache --------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# -------- Mail --------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
#   NAATIA-specific integrations
# ============================================================

# -------- OpenAI --------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -------- WhatsApp Cloud API (Meta) --------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# -------- Public sales/demo numbers (used in landing) --------
# Format: country code + national number (digits only, no + or spaces)
DEMO_WHATSAPP=5215500000000
SALES_WHATSAPP=5215500000000

# -------- Stripe (optional) --------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# -------- MercadoPago (optional) --------
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_URL=

# -------- Payment redirect URLs --------
PAYMENT_SUCCESS_URL="${APP_URL}/payment/success"
PAYMENT_FAILURE_URL="${APP_URL}/payment/failure"
PAYMENT_PENDING_URL="${APP_URL}/payment/pending"

# -------- Vite --------
VITE_APP_NAME="${APP_NAME}"
